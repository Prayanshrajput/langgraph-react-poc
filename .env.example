ANTHROPIC_API_KEY=your_api_key_here
PORT=3000

# GitHub — github.com → Settings → Developer Settings → Fine-grained tokens
# Required permissions: Contents (read/write), Administration (read/write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_USERNAME=your-github-username

# Cloudflare — dash.cloudflare.com → My Profile → API Tokens → Create Token
# Use "Edit Cloudflare Pages" template  
CLOUDFLARE_TOKEN=xxxxxxxxxxxx
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxx
